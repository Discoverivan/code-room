{
  "name": "code-room",
  "version": "0.1.0",
  "description": "A minimal self-hosted real-time collaborative editor.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Discoverivan/code-room.git"
  },
  "bugs": {
    "url": "https://github.com/Discoverivan/code-room/issues"
  },
  "homepage": "https://github.com/Discoverivan/code-room#readme",
  "keywords": [
    "collaboration",
    "editor",
    "self-hosted",
    "yjs"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node server-dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.43.6",
    "@fastify/static": "^10.1.0",
    "@fastify/websocket": "^11.3.0",
    "@uiw/codemirror-theme-github": "^4.25.11",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.10.0",
    "lib0": "^0.2.114",
    "nanoid": "^6.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.18.1",
    "ws": "^8.21.1",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tsx": "^4.23.1",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
